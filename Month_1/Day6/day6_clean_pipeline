import csv
import sys
sys.path.insert(0, 'Day4')
from day4_performance_classifier import classify_performance

clean_results = []
skipped = []

with open("messy_campaigns.csv", "r", encoding='utf-8') as file:
    reader = csv.DictReader(file)

    for row in reader :
        channel = row['channel'].strip().title().replace("_"," ")

        try:
            spend   = int(row['spend'])
            revenue = int(row['revenue'])
            roi     =(revenue - spend) / spend *100

            performance = classify_performance(roi)
            clean_results.append({"channel": channel, "spend": spend, "revenue": revenue,"roi": round(roi,1),"performance": performance})

        except (ValueError,ZeroDivisionError):
            skipped.append(channel)


# Write clean results 

with open("clean_campaigns.csv", "w", newline='', encoding='utf-8') as file:
    writer = csv.DictWriter(file, fieldnames=["channel", "spend", "revenue","roi","performance"])
    writer.writeheader()
    writer.writerows(clean_results)

    print (f"Done {len(clean_results)} clean records written to 'clean_campaigns.csv'")
    print (f"Skipped {len(skipped)} records due to invalid data: {skipped} ")
    